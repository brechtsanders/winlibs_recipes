export NAME="VapourSynth"
export STATUS=
export URL=http://www.vapoursynth.com/
export BASENAME=vapoursynth
export DESCRIPTION="VapourSynth is an application for video manipulation. Or a plugin. Or a library. It's hard to tell because it has a core library written in C++ and a Python module to allow video scripts to be created."
export CATEGORY=video
export TYPE=library
#export VERSION=R75
#export VERSIONDATE=20260501
#export VERSION=R76
#export VERSIONDATE=20260515
export VERSION=R77
export VERSIONDATE=20260616
wl-showstatus --package-version
export DEPENDENCIES=zimg
export OPTIONALDEPENDENCIES=
export BUILDDEPENDENCIES=meson,ninja,cython
export OPTIONALBUILDDEPENDENCIES=
export LICENSEFILE=COPYING.LESSER
export LICENSETYPE=LGPL
export DOWNLOADURL="https://github.com/vapoursynth/vapoursynth/releases"
export INSTALLPREFIX=`pwd`/inst_$BASENAME-$VERSION
export DOWNLOADSOURCEURL=https://github.com/vapoursynth/vapoursynth/archive/refs/tags/$VERSION.tar.gz
wl-showstatus download
wl-download -v -d $TARBALLDIR/$BASENAME $DOWNLOADSOURCEURL
wl-wait4deps
wl-showstatus extract
tar xz --force-local -f $TARBALLDIR/$BASENAME/$VERSION.tar.gz
cd $BASENAME-$VERSION
mkdir -p build_both &&
 wl-showstatus configure &&
 PATH=$MINGWPREFIX/python/Scripts:$PYDIR:$PATH PYTHONPATH=$MINGWPREFIX/python/Lib/site-packages:$PYDIR/Lib/site-packages${PYTHONPATH:+:$PYTHONPATH} $PYDIR/python.exe $(which meson.py) setup --prefix $INSTALLPREFIX --backend ninja --buildtype release --strip --default-library both $PWD build_both &&
 wl-showstatus build-install &&
 PATH=$MINGWPREFIX/python/Scripts:$PYDIR:$PATH PYTHONPATH=$MINGWPREFIX/python/Lib/site-packages${PYTHONPATH:+:$PYTHONPATH} \
 ninja -Cbuild_both install &&
 wl-makepackage -c -d && wl-install -d $BASENAME-$VERSION && cd .. && wl-showstatus cleanup && rm -rf $BASENAME-$VERSION



