export NAME="gerbv"
export STATUS=
export URL=https://gerbv.github.io/
export BASENAME=gerbv
export DESCRIPTION="Gerbv is a viewer for Gerber RS-274X files, Excellon drill files, and CSV pick-and-place files."
export CATEGORY=manufacturing
export TYPE=library,application
export VERSION=2.13.0
export VERSIONDATE=20260322
wl-showstatus --package-version
export DEPENDENCIES=gettext,gtk2
export OPTIONALDEPENDENCIES=dxflib
export BUILDDEPENDENCIES=cmake,ninja
export OPTIONALBUILDDEPENDENCIES=
export LICENSEFILE=COPYING
export LICENSETYPE=GPL
export DOWNLOADURL="https://github.com/gerbv/gerbv/releases"
export INSTALLPREFIX=`pwd`/inst_$BASENAME-$VERSION
export DOWNLOADSOURCEURL=https://github.com/gerbv/gerbv/archive/refs/tags/v$VERSION.tar.gz
wl-showstatus download
wl-download -v -d $TARBALLDIR/$BASENAME $DOWNLOADSOURCEURL
wl-wait4deps
wl-showstatus extract
tar xz --force-local -f $TARBALLDIR/$BASENAME/v$VERSION.tar.gz
cd $BASENAME-$VERSION
# skip installing dependency DLLs in cmake/InstallWindowsDLLs.cmake (version >= 2.13.0)
patch -ulbf cmake/InstallWindowsDLLs.cmake << EOF
@@ -58,2 +58,3 @@

+if(NOT MINGW)
 install(CODE "
@@ -98 +99,2 @@
 ")
+endif()
EOF
mkdir -p build_both build_shared &&
 wl-showstatus configure &&
 cmake.exe -Wno-dev -GNinja -DCMAKE_INSTALL_PREFIX:PATH=$INSTALLPREFIX -DCMAKE_BUILD_TYPE:STRING=Release -DBUILD_SHARED_LIBS:BOOL=ON -DSTANDALONE:BOOL=OFF -DUSE_DL:BOOL=OFF -DCMAKE_C_FLAGS:STRING="-DWIN32" -S. -Bbuild_both &&
 wl-showstatus build-install &&
 ninja -Cbuild_both install/strip &&
 wl-makepackage -c -d && wl-install -d $BASENAME-$VERSION && cd .. && wl-showstatus cleanup && rm -rf $BASENAME-$VERSION



