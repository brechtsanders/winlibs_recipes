mkdir -p build_static build_shared &&
 wl-showstatus configure-static &&
 #cmake.exe -Wno-dev -GNinja -DCMAKE_INSTALL_PREFIX:PATH=$INSTALLPREFIX/share/awtk -DCMAKE_BUILD_TYPE:STRING=Release -DBUILD_SHARED_LIBS:BOOL=OFF -DAWTK_BUILD_SHARED:BOOL=OFF -DLIBSAMPLERATE:BOOL=ON -DCLOCK_GETTIME:BOOL=ON -DDIRECTX:BOOL=OFF -DVIDEO_X11:BOOL=OFF -DPTHREADS:BOOL=ON -DAWTK_SDL_VERSION:STRING=2 -DAWTK_SDL_VIDEODRIVER:STRING=directx -DAWTK_BUILD_TOOLS:BOOL=ON -DAWTK_DEBUG:BOOL=OFF -DAWTK_BUILD_DEMOS:BOOL=ON -DAWTK_BUILD_TESTS:BOOL=OFF -S. -Bbuild_static &&
 cmake.exe -Wno-dev -GNinja -DCMAKE_INSTALL_PREFIX:PATH=$INSTALLPREFIX/share/awtk -DCMAKE_BUILD_TYPE:STRING=Release -DBUILD_SHARED_LIBS:BOOL=OFF -DAWTK_BUILD_SHARED:BOOL=OFF -DLIBSAMPLERATE:BOOL=ON -DCLOCK_GETTIME:BOOL=ON -DDIRECTX:BOOL=OFF -DVIDEO_X11:BOOL=OFF -DPTHREADS:BOOL=ON -DAWTK_SDL_VERSION:STRING=3 -DAWTK_SDL_VIDEODRIVER:STRING=directx -DAWTK_BUILD_TOOLS:BOOL=ON -DAWTK_DEBUG:BOOL=OFF -DAWTK_BUILD_DEMOS:BOOL=ON -DAWTK_BUILD_TESTS:BOOL=OFF -DCMAKE_C_FLAGS:STRING="-DSDL_ENABLE_OLD_NAMES" -S. -Bbuild_static &&
 wl-showstatus configure-shared &&
 #cmake.exe -Wno-dev -GNinja -DCMAKE_INSTALL_PREFIX:PATH=$INSTALLPREFIX/share/awtk -DCMAKE_BUILD_TYPE:STRING=Release -DBUILD_SHARED_LIBS:BOOL=ON -DAWTK_BUILD_SHARED:BOOL=OFF -DLIBSAMPLERATE:BOOL=ON -DCLOCK_GETTIME:BOOL=ON -DDIRECTX:BOOL=OFF -DVIDEO_X11:BOOL=OFF -DPTHREADS:BOOL=ON -DAWTK_SDL_VERSION:STRING=2 -DAWTK_SDL_VIDEODRIVER:STRING=directx -DAWTK_BUILD_TOOLS:BOOL=ON -DAWTK_DEBUG:BOOL=OFF -DAWTK_BUILD_DEMOS:BOOL=ON -DAWTK_BUILD_TESTS:BOOL=OFF -S. -Bbuild_shared &&
 cmake.exe -Wno-dev -GNinja -DCMAKE_INSTALL_PREFIX:PATH=$INSTALLPREFIX/share/awtk -DCMAKE_BUILD_TYPE:STRING=Release -DBUILD_SHARED_LIBS:BOOL=ON -DAWTK_BUILD_SHARED:BOOL=OFF -DLIBSAMPLERATE:BOOL=ON -DCLOCK_GETTIME:BOOL=ON -DDIRECTX:BOOL=OFF -DVIDEO_X11:BOOL=OFF -DPTHREADS:BOOL=ON -DAWTK_SDL_VERSION:STRING=3 -DAWTK_SDL_VIDEODRIVER:STRING=directx -DAWTK_BUILD_TOOLS:BOOL=ON -DAWTK_DEBUG:BOOL=OFF -DAWTK_BUILD_DEMOS:BOOL=ON -DAWTK_BUILD_TESTS:BOOL=OFF -DCMAKE_C_FLAGS:STRING="-DSDL_ENABLE_OLD_NAMES" -S. -Bbuild_shared &&
 wl-showstatus build-install-static &&
 ninja -Cbuild_static install/strip &&
 wl-showstatus build-install-shared &&
 ninja -Cbuild_shared install/strip &&
    echo OK
