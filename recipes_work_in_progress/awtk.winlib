export NAME="AWTK"
export STATUS=
export URL=https://github.com/zlgopen/awtk
#export URL=https://gitee.com/zlgopen/awtk
export BASENAME=awtk
export DESCRIPTION="AWTK = Toolkit AnyWhere (a cross-platform embedded GUI)"
export CATEGORY=
export TYPE=library
export VERSION=master
export VERSIONDATE=20260704
wl-showstatus --package-version
#export DEPENDENCIES=sdl2
export DEPENDENCIES=sdl3
export OPTIONALDEPENDENCIES=
#export BUILDDEPENDENCIES=scons
export BUILDDEPENDENCIES=cmake,ninja
export OPTIONALBUILDDEPENDENCIES=
export LICENSEFILE=LICENSE
export LICENSETYPE=LGPL
export DOWNLOADURL="https://github.com/zlgopen/awtk/tags"
export INSTALLPREFIX=`pwd`/inst_$BASENAME-$VERSION
export DOWNLOADSOURCEURL=https://github.com/zlgopen/awtk/archive/refs/heads/$VERSION.tar.gz
wl-showstatus download
wl-download -v -d $TARBALLDIR/$BASENAME $DOWNLOADSOURCEURL
wl-wait4deps
wl-showstatus extract
tar xz --force-local -f $TARBALLDIR/$BASENAME/$VERSION.tar.gz
cd $BASENAME-$VERSION
# fix src/ext_widgets/slide_view/slide_view.c (version >= master)
patch -ulbf src/ext_widgets/slide_view/slide_view.c << EOF
@@ -223,5 +223,5 @@
   pointer_event_init(&abort, EVT_POINTER_DOWN_ABORT, widget, 0, 0);
-  widget_dispatch_event_to_target_recursive(widget, &abort);
+  widget_dispatch_event_to_target_recursive(widget, &abort.e);
   if (slide_view->pressed) {
-    widget_dispatch(widget, &abort);
+    widget_dispatch(widget, &abort.e);
   }
EOF
# fix src/ext_widgets/slide_view/slide_view.c (version >= master)
patch -ulbf src/ext_widgets/slide_view/slide_view.c << EOF
@@ -223,5 +223,5 @@
   pointer_event_init(&abort, EVT_POINTER_DOWN_ABORT, widget, 0, 0);
-  widget_dispatch_event_to_target_recursive(widget, &abort);
+  widget_dispatch_event_to_target_recursive(widget, &abort.e);
   if (slide_view->pressed) {
-    widget_dispatch(widget, &abort);
+    widget_dispatch(widget, &abort.e);
   }
EOF
# fix src/platforms/pc/thread_with_sdl.c (version >= master)
patch -ulbf src/platforms/pc/thread_with_sdl.c << EOF
@@ -53,2 +53,3 @@

+#if SDL_MAJOR_VERSION < 3
   if (SDL_LockMutex(mutex->mutex) != 0) {
@@ -57,2 +58,5 @@
   }
+#else
+  SDL_LockMutex(mutex->mutex);
+#endif

@@ -66,5 +70,8 @@
   ret = SDL_TryLockMutex(mutex->mutex);
+#ifdef SDL_MUTEX_TIMEDOUT
   if (ret == SDL_MUTEX_TIMEDOUT) {
     return RET_TIMEOUT;
-  } else if (ret == 0) {
+  } else
+#endif
+  if (ret == 0) {
     return RET_OK;
@@ -77,2 +84,3 @@
   return_value_if_fail(mutex != NULL, RET_BAD_PARAMS);
+#if SDL_MAJOR_VERSION < 3
   if (SDL_UnlockMutex(mutex->mutex) != 0) {
@@ -81,2 +89,5 @@
   }
+#else
+  SDL_UnlockMutex(mutex->mutex);
+#endif

@@ -126,3 +137,8 @@

+#if SDL_MAJOR_VERSION < 3
   return SDL_CondSignal(cond->cond) == 0 ? RET_OK : RET_FAIL;
+#else
+  SDL_CondSignal(cond->cond);
+  return RET_OK;
+#endif
 }
@@ -132,3 +148,8 @@

+#if SDL_MAJOR_VERSION < 3
   return SDL_CondBroadcast(cond->cond) == 0 ? RET_OK : RET_FAIL;
+#else
+  SDL_CondBroadcast(cond->cond);
+  return RET_OK;
+#endif
 }
@@ -144,3 +165,8 @@

+#if SDL_MAJOR_VERSION < 3
   return SDL_CondWait(cond->cond, mutex->mutex) == 0 ? RET_OK : RET_FAIL;
+#else
+  SDL_CondWait(cond->cond, mutex->mutex);
+  return RET_OK;
+#endif
 }
@@ -170,5 +196,8 @@
   ret = SDL_SemWaitTimeout(semaphore->sem, timeout_ms);
+#ifdef SDL_MUTEX_TIMEDOUT
   if (ret == SDL_MUTEX_TIMEDOUT) {
     return RET_TIMEOUT;
-  } else if (ret == 0) {
+  } else
+#endif
+  if (ret == 0) {
     return RET_OK;
@@ -182,3 +211,8 @@

+#if SDL_MAJOR_VERSION < 3
   return SDL_SemPost(semaphore->sem) == 0 ? RET_OK : RET_FAIL;
+#else
+  SDL_SemPost(semaphore->sem);
+  return RET_OK;
+#endif
 }
EOF
